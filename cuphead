<!DOCTYPE html>
<html lang="en-us">
<head>
  <base href="https://cdn.jsdelivr.net/gh/web-ports/cuphead@c9ff1b6b16f9d402b78a42fc2200e1c076c0ab6e/">

  <meta charset="utf-8">
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=no">

  <title>Cuphead Web Port</title>

  <style>
    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
    }

    html,body{
      width:100%;
      height:100%;
      overflow:hidden;
      background:#000;
      font-family:Arial, sans-serif;
    }

    body{
      display:flex;
      align-items:center;
      justify-content:center;
    }

    #gameContainer{
      width:100vw;
      height:100vh;
      position:relative;
      background:#000;
    }

    canvas{
      width:100% !important;
      height:100% !important;
      image-rendering:auto;
    }

    /* FAST GPU loading screen */
    #loader{
      position:absolute;
      inset:0;
      display:flex;
      flex-direction:column;
      align-items:center;
      justify-content:center;
      background:#000;
      z-index:999;
      will-change:transform;
    }

    #logo{
      font-size:52px;
      font-weight:900;
      letter-spacing:3px;

      background:linear-gradient(
        90deg,
        #ff0000,
        #ff7f00,
        #ffff00,
        #00ff00,
        #00ffff,
        #0000ff,
        #ff00ff,
        #ff0000
      );

      background-size:300% 100%;
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;

      animation:rainbow 4s linear infinite;

      text-shadow:0 0 25px rgba(255,255,255,.15);
    }

    @keyframes rainbow{
      0%{background-position:0% 50%;}
      100%{background-position:300% 50%;}
    }

    #loading-text{
      color:#fff;
      margin-top:18px;
      font-size:18px;
      font-weight:700;
    }

    #bar{
      width:min(500px,85vw);
      height:18px;
      background:#111;
      border-radius:999px;
      margin-top:22px;
      overflow:hidden;
      border:2px solid #222;
    }

    #bar-fill{
      width:0%;
      height:100%;
      border-radius:999px;

      background:linear-gradient(
        90deg,
        #ff0000,
        #ffff00,
        #00ff00,
        #00ffff
      );

      transition:width .15s linear;
    }

    #tips{
      position:absolute;
      bottom:18px;
      color:#999;
      font-size:13px;
      text-align:center;
      padding:0 20px;
    }

    /* Low-end Chromebook optimization */
    @media (max-width:900px){

      #logo{
        font-size:34px;
      }

      #loading-text{
        font-size:15px;
      }

      #bar{
        height:14px;
      }
    }
  </style>
</head>

<body>

<div id="gameContainer">

  <div id="loader">
    <div id="logo">CUPHEAD</div>

    <div id="loading-text">
      Preparing game...
    </div>

    <div id="bar">
      <div id="bar-fill"></div>
    </div>

    <div id="tips">
      Optimized for low-end Chromebooks • Fast Cache • Reduced Lag
    </div>
  </div>

</div>

<script src="Build/UnityLoader.js"></script>

<script>

const loadingText = document.getElementById("loading-text");
const barFill = document.getElementById("bar-fill");
const loader = document.getElementById("loader");

const CACHE_NAME = "cuphead-ultra-cache-v2";

/* LOW-END PERFORMANCE BOOSTS */
const LOW_END_DEVICE =
  navigator.deviceMemory <= 4 ||
  navigator.hardwareConcurrency <= 4;

/* Disable expensive effects on weak devices */
if (LOW_END_DEVICE) {
  document.body.style.imageRendering = "pixelated";
}

/* Prevent tab lag spikes */
document.addEventListener("visibilitychange", () => {
  if (document.hidden) {
    try {
      unityInstance.Module.pauseMainLoop();
    } catch(e){}
  }
});

/* Better fetch with streaming */
async function fetchWithProgress(url, totalExpected) {

  const cache = await caches.open(CACHE_NAME);

  const cached = await cache.match(url);

  if (cached) {
    return await cached.arrayBuffer();
  }

  const response = await fetch(url, {
    cache: "force-cache"
  });

  const reader = response.body.getReader();

  let received = 0;
  let chunks = [];

  while (true) {

    const {done, value} = await reader.read();

    if (done) break;

    chunks.push(value);

    received += value.length;

    globalLoaded += value.length;

    const percent =
      ((globalLoaded / TOTAL_BYTES) * 100).toFixed(1);

    const mbDone =
      (globalLoaded / 1024 / 1024).toFixed(1);

    const mbTotal =
      (TOTAL_BYTES / 1024 / 1024).toFixed(1);

    loadingText.textContent =
      `Loading ${percent}% • ${mbDone}MB / ${mbTotal}MB`;

    barFill.style.width = percent + "%";
  }

  const blob = new Blob(chunks);

  cache.put(url, new Response(blob));

  return await blob.arrayBuffer();
}

/* Merge split files faster */
async function mergeFiles(parts, cacheKey) {

  const cache = await caches.open(CACHE_NAME);

  const existing = await cache.match(cacheKey);

  if (existing) {
    const blob = await existing.blob();
    return URL.createObjectURL(blob);
  }

  const buffers = await Promise.all(
    parts.map(part => fetchWithProgress(part))
  );

  const merged = new Blob(buffers);

  await cache.put(cacheKey, new Response(merged));

  return URL.createObjectURL(merged);
}

function getParts(file, start, end) {

  let arr = [];

  for (let i = start; i <= end; i++) {
    arr.push(file + ".part" + i);
  }

  return arr;
}

/* Approximate total size */
const TOTAL_BYTES =
  (103 * 20 * 1024 * 1024) +
  (2 * 15 * 1024 * 1024) +
  (3 * 8 * 1024 * 1024);

let globalLoaded = 0;

let unityInstance;

(async () => {

  loadingText.textContent = "Preparing ultra-fast cache...";

  const [dataUrl, wasmUrl, asmUrl] = await Promise.all([

    mergeFiles(
      getParts("Build/CupheadPort.data.unityweb", 1, 103),
      "CupheadPort.data.unityweb"
    ),

    mergeFiles(
      getParts("Build/CupheadPort.wasm.code.unityweb", 1, 2),
      "CupheadPort.wasm.code.unityweb"
    ),

    mergeFiles(
      getParts("Build/CupheadPort.asm.code.unityweb", 1, 3),
      "CupheadPort.asm.code.unityweb"
    )

  ]);

  /* Redirect Unity requests */
  const originalOpen = XMLHttpRequest.prototype.open;

  XMLHttpRequest.prototype.open = function(method, url, ...rest){

    if(url.includes("CupheadPort.data.unityweb")){
      url = dataUrl;
    }

    else if(url.includes("CupheadPort.wasm.code.unityweb")){
      url = wasmUrl;
    }

    else if(url.includes("CupheadPort.asm.code.unityweb")){
      url = asmUrl;
    }

    return originalOpen.call(this, method, url, ...rest);
  };

  /* Unity performance config */
  unityInstance = UnityLoader.instantiate(
    "gameContainer",
    "Build/CupheadPort.json",
    {
      Module: {
        TOTAL_MEMORY: LOW_END_DEVICE
          ? 268435456
          : 536870912
      },

      onProgress: function(instance, progress){

        const percent = Math.floor(progress * 100);

        barFill.style.width = percent + "%";

        loadingText.textContent =
          `Starting Game ${percent}%`;
      }
    }
  );

  /* Smooth remove loader */
  setTimeout(() => {

    loader.style.transition = "opacity .6s ease";

    loader.style.opacity = "0";

    setTimeout(() => {
      loader.remove();
    }, 700);

  }, 1200);

})();

/* FPS boost */
window.addEventListener("contextmenu", e => e.preventDefault());

/* Prevent accidental zoom lag */
document.addEventListener("gesturestart", e => {
  e.preventDefault();
});

/* Reduce resize lag */
let resizeTimer;

window.addEventListener("resize", () => {

  clearTimeout(resizeTimer);

  resizeTimer = setTimeout(() => {

    const canvas = document.querySelector("canvas");

    if(canvas){
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

  }, 120);
});

</script>

</body>
</html>
